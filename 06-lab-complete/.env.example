# ─────────────────────────────────────────────────
# Copy thành .env.local và điền giá trị thật
# ❌ KHÔNG commit file .env.local lên Git
# ─────────────────────────────────────────────────

# Server
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
DEBUG=false

# App
APP_NAME=Production AI Agent
APP_VERSION=1.0.0

# LLM (để trống = dùng mock LLM, không cần key thật)
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# Security — BẮT BUỘC thay trong production
AGENT_API_KEY=dev-key-change-me-in-production

# Rate & Budget
RATE_LIMIT_PER_MINUTE=10
MONTHLY_BUDGET_USD=10.0

# Storage
REDIS_URL=redis://localhost:6379/0

# Logging
LOG_LEVEL=INFO

# CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
